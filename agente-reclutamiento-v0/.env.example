# ============================================
# CONFIGURACIÓN DEL SISTEMA DE EXTRACCIÓN DE CVs
# ============================================

# API Key de Google Gemini (requerida)
GEMINI_API_KEY=tu_api_key_aqui

# Ruta de la carpeta con los CVs (solo lectura)
